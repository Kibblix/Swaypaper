#!/bin/bash

# Wallpaper Directory default
DEFAULT_DIR="$HOME/Pictures/Wallpapers"

# Config
CONFIG_DIR="$HOME/.config/swaypaper"
CONFIG_FILE="$CONFIG_DIR/config"

# Sway stuff
SWAY_CONFIG="$HOME/.config/sway/config"
LINK_PATH="$HOME/.config/sway/current_wallpaper"
LINE='exec_always swaybg -i ~/.config/sway/current_wallpaper -m fill'




# Supported formats
EXTENSIONS=("jpg" "jpeg" "png" "webp")


# Load configs

mkdir -p "$CONFIG_DIR"

# defaults (fallbacks only)
WALLPAPER_DIR="$DEFAULT_DIR"
SWAY_INTEGRATION=""

# load existing config
if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
fi

# apply fallback if missing
WALLPAPER_DIR="${WALLPAPER_DIR:-$DEFAULT_DIR}"

# detect first run
if [[ ! -f "$CONFIG_FILE" ]]; then
    FIRST_RUN=true
else
    FIRST_RUN=false
fi

LINE='exec_always swaybg -i ~/.config/sway/current_wallpaper -m fill'
SWAY_CONFIG="$HOME/.config/sway/config"

# First run wizard 

if $FIRST_RUN; then
    echo "First run setup for swaypaper"
    echo

    read -rp "Wallpaper directory [$DEFAULT_DIR]: " input_dir
    WALLPAPER_DIR="${input_dir:-$DEFAULT_DIR}"

    echo
    echo "Sway requires this line for wallpaper support:"
    echo
    echo "  $LINE"
    echo

    read -rp "Add it to your sway config? [y/N]: " ans

    SWAY_INTEGRATION="no"

    if [[ "$ans" =~ ^[Yy]$ ]]; then
        mkdir -p "$HOME/.config/sway"
        touch "$SWAY_CONFIG"

        if ! grep -Fxq "$LINE" "$SWAY_CONFIG"; then
            echo "" >> "$SWAY_CONFIG"
            echo "# added by swaypaper" >> "$SWAY_CONFIG"
            echo "$LINE" >> "$SWAY_CONFIG"
        fi

        SWAY_INTEGRATION="yes"
    fi

    # save config
    cat > "$CONFIG_FILE" <<EOF
WALLPAPER_DIR=$WALLPAPER_DIR
SWAY_INTEGRATION=$SWAY_INTEGRATION
EOF

    echo
    echo "Setup complete."
    echo
fi


# hide cursor
tput civis

cleanup() {
    tput cnorm
    clear
}

trap cleanup EXIT

wallpapers=()

for ext in "${EXTENSIONS[@]}"; do
    while IFS= read -r -d '' file; do
        wallpapers+=("$file")
    done < <(find "$WALLPAPER_DIR" -type f -iname "*.$ext" -print0)
done

if [ ${#wallpapers[@]} -eq 0 ]; then
    echo "No wallpapers found."
    exit 1
fi

# sort alphabetically
IFS=$'\n' wallpapers=($(sort <<<"${wallpapers[*]}"))
unset IFS

selected=0

clear

draw_menu() {
    # move cursor to top instead of clear
    printf "\033[H"

    echo "swayselect v2"
    echo ""
    echo "↑ ↓ navigate    ENTER apply    Q quit"
    echo ""

    for i in "${!wallpapers[@]}"; do
        name=$(basename "${wallpapers[$i]}")

        if [ "$i" -eq "$selected" ]; then
            printf "\033[1;37;44m > %s \033[0m\n" "$name"
        else
            printf "   %s\n" "$name"
        fi
    done

    # clear leftover lines
    printf "\033[J"
}

draw_menu

# input loop

while true; do
    IFS= read -rsn1 key

    if [[ $key == $'\x1b' ]]; then
        read -rsn2 key

        case $key in
            "[A")
                ((selected--))
                ((selected < 0)) && selected=$((${#wallpapers[@]} - 1))
                ;;
            "[B")
                ((selected++))
                ((selected >= ${#wallpapers[@]})) && selected=0
                ;;
        esac

        draw_menu

    elif [[ $key == "" ]]; then

      chosen="${wallpapers[$selected]}"

      mkdir -p "$(dirname "$LINK_PATH")"

      ln -sf "$chosen" "$LINK_PATH"

      pkill swaybg

      swaybg -i "$chosen" -m fill >/dev/null 2>&1 &

      printf "\033[H"
      echo "Wallpaper applied:"
      echo ""
      echo "$(basename "$chosen")"

      sleep 1
      exit 0
    elif [[ $key == "q" || $key == "Q" ]]; then
        exit 0
    fi
done
