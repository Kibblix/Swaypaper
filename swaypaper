#!/bin/bash

DEFAULT_DIR="$HOME/Pictures/Wallpapers"

CONFIG_DIR="$HOME/.config/swaypaper"
CONFIG_FILE="$CONFIG_DIR/config"

LINK_PATH="$HOME/.config/sway/current_wallpaper"

EXTENSIONS=("jpg" "jpeg" "png" "webp")

mkdir -p "$CONFIG_DIR"

WALLPAPER_DIR="$DEFAULT_DIR"
AUTOSTART_CONFIG=""
AUTOSTART_LINE=""

if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
fi

WALLPAPER_DIR="${WALLPAPER_DIR:-$DEFAULT_DIR}"

if [[ ! -f "$CONFIG_FILE" ]]; then
    FIRST_RUN=true
else
    FIRST_RUN=false
fi

if $FIRST_RUN; then

    echo "First run setup for swaypaper"
    echo

    read -rp "Wallpaper directory [$DEFAULT_DIR]: " input_dir
    WALLPAPER_DIR="${input_dir:-$DEFAULT_DIR}"

    echo
    echo "Choose your compositor:"
    echo
    echo "1) Hyprland"
    echo "2) Sway"
    echo "3) Niri"
    echo "4) i3"
    echo "5) Manual"
    echo

    read -rp "Selection: " compositor

    case "$compositor" in

        1)
            AUTOSTART_CONFIG="$HOME/.config/hypr/hyprland.conf"
            AUTOSTART_LINE='exec-once = swaybg -i $HOME/.config/sway/current_wallpaper -m fill'
            ;;

        2)
            AUTOSTART_CONFIG="$HOME/.config/sway/config"
            AUTOSTART_LINE='exec swaybg -i $HOME/.config/sway/current_wallpaper -m fill'
            ;;

        3)
            AUTOSTART_CONFIG="$HOME/.config/niri/config.kdl"
            spawn-at-startup "swaybg" "-i" "/home/jacob/.config/sway/current_wallpaper" "-m" "fill"
            ;;

        4)
            AUTOSTART_CONFIG="$HOME/.config/i3/config"
            AUTOSTART_LINE='exec --no-startup-id swaybg -i $HOME/.config/sway/current_wallpaper -m fill'
            ;;

        5)
            echo
            echo "Add this manually to your compositor startup:"
            echo
            echo "swaybg -i $HOME/.config/sway/current_wallpaper -m fill"
            echo
            ;;
    esac

    if [[ -n "$AUTOSTART_CONFIG" ]]; then

        echo
        echo "Autostart line:"
        echo
        echo "$AUTOSTART_LINE"
        echo

        read -rp "Add automatically? [y/N]: " ans

        if [[ "$ans" =~ ^[Yy]$ ]]; then

            mkdir -p "$(dirname "$AUTOSTART_CONFIG")"
            touch "$AUTOSTART_CONFIG"

            BLOCK_START="# >>> swaypaper start"
            BLOCK_END="# <<< swaypaper end"

            NEW_BLOCK="$BLOCK_START
$AUTOSTART_LINE
$BLOCK_END"

            if grep -q "$BLOCK_START" "$AUTOSTART_CONFIG"; then
                awk -v start="$BLOCK_START" -v end="$BLOCK_END" -v new="$NEW_BLOCK" '
                $0 == start {print new; in_block=1; next}
                $0 == end {in_block=0; next}
                !in_block
                ' "$AUTOSTART_CONFIG" > "${AUTOSTART_CONFIG}.tmp" \
                && mv "${AUTOSTART_CONFIG}.tmp" "$AUTOSTART_CONFIG"

                echo
                echo "Autostart block updated."
                echo
            else
                {
                    echo
                    echo "$NEW_BLOCK"
                } >> "$AUTOSTART_CONFIG"

                echo
                echo "Autostart block added."
                echo
            fi

        fi

    cat > "$CONFIG_FILE" <<EOF
WALLPAPER_DIR="$WALLPAPER_DIR"
EOF

    echo "Setup complete."
    echo
fi

tput civis

cleanup() {
    tput cnorm
    clear
}

trap cleanup EXIT

wallpapers=()

for ext in "${EXTENSIONS[@]}"; do
    while IFS= read -r -d '' file; do
        wallpapers+=("$file")
    done < <(find "$WALLPAPER_DIR" -type f -iname "*.$ext" -print0)
done

if [[ ${#wallpapers[@]} -eq 0 ]]; then
    echo "No wallpapers found."
    exit 1
fi

IFS=$'\n' wallpapers=($(sort <<<"${wallpapers[*]}"))
unset IFS

selected=0

clear

draw_menu() {

    printf "\033[H"

    echo "swaypaper"
    echo
    echo "↑ ↓ navigate    ENTER apply    Q quit"
    echo

    for i in "${!wallpapers[@]}"; do

        name=$(basename "${wallpapers[$i]}")

        if [[ "$i" -eq "$selected" ]]; then
            printf "\033[1;37;44m > %s \033[0m\n" "$name"
        else
            printf "   %s\n" "$name"
        fi
    done

    printf "\033[J"
}

draw_menu

while true; do

    IFS= read -rsn1 key

    if [[ $key == $'\x1b' ]]; then

        read -rsn2 key

        case $key in

            "[A")
                ((selected--))
                ((selected < 0)) && selected=$((${#wallpapers[@]} - 1))
                ;;

            "[B")
                ((selected++))
                ((selected >= ${#wallpapers[@]})) && selected=0
                ;;

        esac

        draw_menu

    elif [[ $key == "" ]]; then

        chosen="${wallpapers[$selected]}"

        mkdir -p "$(dirname "$LINK_PATH")"

        ln -sf "$chosen" "$LINK_PATH"

        pkill swaybg >/dev/null 2>&1

        swaybg -i "$chosen" -m fill >/dev/null 2>&1 &

        printf "\033[H"

        echo "Wallpaper applied:"
        echo
        echo "$(basename "$chosen")"

        sleep 1
        exit 0

    elif [[ $key == "q" || $key == "Q" ]]; then
        exit 0
    fi
done
